# Database (SQLite file for local development)
DATABASE_URL=file:./local.db
DATABASE_AUTH_TOKEN=

# Redis (optional for local dev; required for Docker/multi-instance)
REDIS_URL=redis://localhost:6379

# Next.js / Auth
NEXTAUTH_SECRET=dev-secret-do-not-use-in-production
NEXT_PUBLIC_API_URL=http://localhost:3000

# AI Providers (configure at least one for real essay corrections)
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=

# Push notifications (optional)
EXPO_ACCESS_TOKEN=

# Docker Compose
WEB_PORT=3000
