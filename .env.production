# ============================================================
# BetterWrite 生产环境配置 — 103.79.186.155
# 生成时间: 2026-07-05
# ============================================================

# ------------------------------------------------------------
# Database（必填）
# ------------------------------------------------------------
DATABASE_URL=file:/app/data/betterwrite.db
DATABASE_AUTH_TOKEN=

# ------------------------------------------------------------
# Redis（必填）
# ------------------------------------------------------------
REDIS_URL=redis://redis:6379

# ------------------------------------------------------------
# Next.js / Auth（必填）
# ------------------------------------------------------------
# 32 字节随机 base64 — 生成于部署前
NEXTAUTH_SECRET=Q3TzW2nP4k6L9R8sV1bX7yM0jH5gKcAeDfNhUiYpBxq
# 对外 API 基地址 — 实际域名待 SSL 申请完成后改为 https://api.cosky.top
NEXT_PUBLIC_API_URL=https://api.cosky.top

# ------------------------------------------------------------
# CORS（按需配置）
# ------------------------------------------------------------
# 允许 Web (www.cosky.top)、管理后台 (admin.cosky.top)、移动端 (app://, exp://) 跨域
CORS_ORIGIN=https://www.cosky.top,https://admin.cosky.top,https://app.cosky.top

# ------------------------------------------------------------
# AI Providers — 占位 Key，待用户补充
# ------------------------------------------------------------
# 用户表示稍后补充；先用占位字符串，应用启动时检测到无效 key 会降级为模拟评分
OPENAI_API_KEY=sk-placeholder-replace-with-real-key
DEEPSEEK_API_KEY=sk-placeholder-replace-with-real-key
ANTHROPIC_API_KEY=

# ------------------------------------------------------------
# OCR（可选）
# ------------------------------------------------------------
OCR_API_KEY=

# ------------------------------------------------------------
# Push notifications（可选）
# ------------------------------------------------------------
# Expo 已通过 CLI 登录，但 token 留空让 EAS 客户端自动从本地缓存读取
EXPO_ACCESS_TOKEN=

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
LOG_LEVEL=info

# ------------------------------------------------------------
# Worker
# ------------------------------------------------------------
WORKER_HEALTH_PORT=8080
WORKER_CONCURRENCY=2

# ------------------------------------------------------------
# Docker Compose
# ------------------------------------------------------------
WEB_PORT=3000
BACKUP_INTERVAL=86400
