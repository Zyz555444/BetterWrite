# Database (SQLite file shared between web/worker via Docker volume)
# For high-write production loads, switch to a remote libsql:// or Turso database.
DATABASE_URL=file:/app/data/betterwrite.db
DATABASE_AUTH_TOKEN=

# Redis (provided by docker-compose; used for shared rate-limiting and caching)
REDIS_URL=redis://redis:6379

# Next.js / Auth
# 生产环境必须设置长度 >= 32 的随机密钥，生成命令：openssl rand -base64 32
NEXTAUTH_SECRET=
NEXT_PUBLIC_API_URL=http://localhost:3000

# CORS origins for API (逗号分隔，例如 https://app.example.com,https://admin.example.com)
# 留空时仅允许同源访问，禁止跨域请求
CORS_ORIGIN=

# AI Providers (configure at least one for real essay corrections)
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=

# Push notifications (optional)
EXPO_ACCESS_TOKEN=

# Logging (trace | debug | info | warn | error | fatal)
LOG_LEVEL=info

# Worker
WORKER_HEALTH_PORT=8080
WORKER_CONCURRENCY=3

# Docker Compose
WEB_PORT=3000
BACKUP_INTERVAL=86400
