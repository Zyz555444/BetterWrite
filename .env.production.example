# ============================================================
# BetterWrite 生产环境部署模板
# 复制本文件为 .env.production，填写必填项后即可一键部署：
#   cp .env.production.example .env.production
#   docker compose --env-file .env.production -f docker/docker-compose.yml up -d
# ============================================================

# ------------------------------------------------------------
# Database（必填）
# ------------------------------------------------------------
# SQLite 文件路径，通过 Docker volume 在 web/worker/migrate 之间共享。
# 高并发写入场景建议切换为远程 libsql:// 或 Turso。
DATABASE_URL=file:/app/data/betterwrite.db
# 远程 libsql 认证令牌（使用本地 SQLite 时留空）
DATABASE_AUTH_TOKEN=

# ------------------------------------------------------------
# Redis（必填）
# ------------------------------------------------------------
# docker-compose.yml 已内置 redis 服务，容器内使用服务名访问。
REDIS_URL=redis://redis:6379

# ------------------------------------------------------------
# Next.js / Auth（必填）
# ------------------------------------------------------------
# 会话加密密钥，生产环境必须设置长度 >= 32 的随机字符串。
# 生成命令：openssl rand -base64 32
NEXTAUTH_SECRET=
# 前端访问 API 的基地址，保持默认即可；若使用反向代理请改为实际域名。
NEXT_PUBLIC_API_URL=http://localhost:3000

# ------------------------------------------------------------
# CORS（可选但建议按需配置）
# ------------------------------------------------------------
# 允许跨域访问 API 的来源，多个用逗号分隔，例如：
# CORS_ORIGIN=https://app.example.com,https://admin.example.com
# 留空时禁止跨域请求，仅允许同源访问。
CORS_ORIGIN=

# ------------------------------------------------------------
# AI Providers（至少填一个，否则批改降级为模拟评分）
# ------------------------------------------------------------
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=

# ------------------------------------------------------------
# OCR（可选）
# ------------------------------------------------------------
# Google Vision API Key，用于手写作文识别；未配置时返回模拟结果。
OCR_API_KEY=

# ------------------------------------------------------------
# Push notifications（可选）
# ------------------------------------------------------------
EXPO_ACCESS_TOKEN=

# ------------------------------------------------------------
# Logging（可选）
# ------------------------------------------------------------
# trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ------------------------------------------------------------
# Worker（可选）
# ------------------------------------------------------------
WORKER_HEALTH_PORT=8080
WORKER_CONCURRENCY=3

# ------------------------------------------------------------
# Docker Compose（可选）
# ------------------------------------------------------------
WEB_PORT=3000
# 备份间隔，单位秒，默认每天一次
BACKUP_INTERVAL=86400
