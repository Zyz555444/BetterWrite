{
  "cli": {
    "version": ">=20.5.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "resourceClass": "medium"
      },
      "android": {
        "resourceClass": "medium"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "resourceClass": "medium"
      },
      "android": {
        "resourceClass": "medium"
      },
      "env": {
        "API_URL": "https://api.cosky.top"
      }
    },
    "production": {
      "ios": {
        "resourceClass": "large"
      },
      "android": {
        "resourceClass": "large"
      },
      "env": {
        "API_URL": "https://api.cosky.top"
      },
      "postbuild": "node scripts/restore-package-json.js || true"
    }
  },
  "submit": {
    "production": {}
  }
}
