    "@betterwrite/shared": "workspace:*",
    "bullmq": "^5.48.0",
    "drizzle-orm": "^0.38.0",
    "ioredis": "5.10.1",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "@betterwrite/tsconfig": "workspace:*",
    "@biomejs/biome": "^1.9.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3"
  }
}
